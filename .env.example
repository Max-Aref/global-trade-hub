# ============================================================
# Global Trade Hub — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# Set all variables in Vercel project settings before deploying.
# ============================================================

# ─── APP ────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://globaltradehub.com
NEXT_PUBLIC_APP_NAME="Global Trade Hub"
NEXT_PUBLIC_APP_ENV=production

# ─── DATABASE ───────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── AUTH ───────────────────────────────────────────────────
NEXTAUTH_URL=https://globaltradehub.com
NEXTAUTH_SECRET=your-secret-here-minimum-32-chars

# ─── OAUTH PROVIDERS ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── EMAIL ──────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="Global Trade Hub <noreply@globaltradehub.com>"

# ─── STORAGE ────────────────────────────────────────────────
STORAGE_BUCKET=
STORAGE_REGION=

# ─── ANALYTICS ──────────────────────────────────────────────
NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your-analytics-id
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── IMAGE SOURCING APIS (dev scripts only) ─────────────────
PEXELS_API_KEY=
PIXABAY_API_KEY=

# ─── MONITORING ─────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
